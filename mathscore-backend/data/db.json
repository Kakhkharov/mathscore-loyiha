            "x = 5",
            "x = 7",
            "x = 9",
            "x = 6"
          ],
          "correctAnswer": 1,
          "score": 4,
          "explanation": "3x = 21 => x = 7."
        },
        {
          "id": 2,
          "type": "single",
          "text": "Berilgan aniq integralni hisoblang: \\int_{0}^{2} (3x^2 - 2x) dx",
          "options": [
            "4",
            "6",
            "8",
            "10"
          ],
          "correctAnswer": 0,
          "score": 5,
          "explanation": "F(x) = x^3 - x^2. F(2) - F(0) = 8 - 4 = 4."
        }
      ]
