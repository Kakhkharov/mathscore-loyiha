generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model LandingSettings {
  id             Int      @id @default(1)
  heroTitle      String
  heroSubtitle   String
  contactPhone   String
  contactAddress String
  telegramLink   String
  updatedAt      DateTime @updatedAt
}

model Result {
  id        Int      @id @default(autoincrement())
  score     String
  name      String
  color     String   @default("text-primary")
  createdAt DateTime @default(now())
}

model Pricing {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       String
  type        String   @default("primary")
  createdAt   DateTime @default(now())
}
